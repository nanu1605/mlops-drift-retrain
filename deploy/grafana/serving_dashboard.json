{
  "__comment": "Serving panels over the /metrics series. Provisioned in compose and as a labeled ConfigMap on minikube.",
  "title": "Intrusion Serving",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (endpoint) (rate(requests_total[5m]))", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "id": 2,
      "title": "Predict latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(predict_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3,
      "title": "Predicted class distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (predicted_class) (rate(predictions_total[5m]))", "legendFormat": "class {{predicted_class}}" }
      ]
    },
    {
      "id": 4,
      "title": "Live champion model version",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "model_version" }]
    },
    {
      "id": 5,
      "title": "Rejected requests (4xx)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "expr": "sum(increase(prediction_errors_total[1h]))" }]
    }
  ]
}
